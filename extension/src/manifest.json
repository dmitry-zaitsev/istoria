{
  "manifest_version": 3,
  "name": "istoria browser logs",
  "version": "1.1.0",
  "description": "Stream browser console + network events from the active tab into the local istoria desktop app.",
  "minimum_chrome_version": "120",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "istoria browser logs",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
